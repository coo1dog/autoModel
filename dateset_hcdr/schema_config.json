{
  "relationships": [
    {
      "name": "application_to_bureau",
      "from_table": "bureau",
      "from_field": "SK_ID_CURR",
      "from_entity": "bureau",
      "to_table": "application_train",
      "to_field": "SK_ID_CURR",
      "to_entity": "application_train",
      "type": "many_to_one",
      "from_key": "SK_ID_CURR",
      "to_key": "SK_ID_CURR",
      "cardinality": "0..*",
      "description": "一个客户可以有0到多条征信局信贷记录",
      "business_meaning": "通过客户ID关联,了解客户在其他金融机构的信用历史",
      "aggregation_examples": [
        "COUNT: 统计客户的历史信贷数量",
        "SUM(AMT_CREDIT_SUM_DEBT): 计算客户在其他机构的总欠款",
        "MAX(CREDIT_DAY_OVERDUE): 查找客户历史最严重的逾期天数",
        "AVG(AMT_CREDIT_MAX_OVERDUE): 计算平均历史逾期金额"
      ]
    },
    {
      "name": "application_to_installments",
      "from_table": "installments_payments",
      "from_field": "SK_ID_CURR",
      "from_entity": "installments_payments",
      "to_table": "application_train",
      "to_field": "SK_ID_CURR",
      "to_entity": "application_train",
      "type": "many_to_one",
      "from_key": "SK_ID_CURR",
      "to_key": "SK_ID_CURR",
      "cardinality": "0..*",
      "description": "一个客户(申请)对应多期分期还款记录",
      "business_meaning": "用于构建分期表现相关的跨表聚合特征，如逾期、还款金额等",
      "aggregation_examples": [
        "COUNT: 统计分期还款期数",
        "SUM(AMT_PAYMENT): 累计实际还款金额",
        "AVG(DAYS_ENTRY_PAYMENT - DAYS_INSTALMENT): 平均提前/延迟天数",
        "MAX(NUM_INSTALMENT_NUMBER): 最大期次"
      ]
    },
    {
      "name": "application_to_previous",
      "from_table": "previous_application",
      "from_field": "SK_ID_CURR",
      "from_entity": "previous_application",
      "to_table": "application_train",
      "to_field": "SK_ID_CURR",
      "to_entity": "application_train",
      "type": "many_to_one",
      "from_key": "SK_ID_CURR",
      "to_key": "SK_ID_CURR",
      "cardinality": "0..*",
      "description": "一个客户可以有0到多次在Home Credit的历史申请",
      "business_meaning": "通过客户ID关联,了解客户在本公司的申请历史行为特征",
      "aggregation_examples": [
        "COUNT: 统计客户历史申请总次数",
        "COUNT WHERE NAME_CONTRACT_STATUS='Refused': 统计被拒次数",
        "COUNT WHERE NAME_CONTRACT_STATUS='Approved': 统计批准次数",
        "SUM(AMT_CREDIT): 计算客户历史累计借款总额",
        "AVG(AMT_APPLICATION - AMT_CREDIT): 计算平均申请与批准金额差异",
        "MAX(DAYS_DECISION): 最长决策时间",
        "COUNT(DISTINCT CODE_REJECT_REASON): 被拒原因种类数"
      ]
    }
  ],
  "business_rules": [
    {
      "name": "debt_to_income_ratio",
      "formula": "AMT_CREDIT / AMT_INCOME_TOTAL",
      "description": "负债收入比",
      "tables": [
        "application_train"
      ],
      "threshold": {
        "warning": 0.5,
        "danger": 0.8
      },
      "business_meaning": "比值越高,还款压力越大,违约风险越高"
    },
    {
      "name": "previous_refused_count",
      "formula": "COUNT(previous_application WHERE NAME_CONTRACT_STATUS='Refused')",
      "description": "历史被拒次数",
      "tables": [
        "previous_application"
      ],
      "aggregation": "COUNT",
      "business_meaning": "被拒次数多的客户风险可能更高",
      "high_value": true
    },
    {
      "name": "previous_approval_rate",
      "formula": "COUNT(WHERE STATUS='Approved') / COUNT(*)",
      "description": "历史申请批准率",
      "tables": [
        "previous_application"
      ],
      "aggregation": "RATE",
      "business_meaning": "批准率低可能表示信用评级不高",
      "high_value": true
    },
    {
      "name": "credit_approval_ratio",
      "formula": "AVG(AMT_CREDIT / AMT_APPLICATION)",
      "description": "历史申请平均批准比例",
      "tables": [
        "previous_application"
      ],
      "aggregation": "AVG",
      "business_meaning": "比例低可能表示信用评级不高或申请金额不合理",
      "high_value": true
    }
  ],
  "feature_engineering_hints": [
    {
      "category": "previous_application_aggregation",
      "priority": "HIGH",
      "examples": [
        {
          "name": "prev_refused_count",
          "formula": "COUNT(previous_application WHERE NAME_CONTRACT_STATUS='Refused')",
          "description": "历史被拒次数 - 强特征"
        },
        {
          "name": "prev_approved_count",
          "formula": "COUNT(previous_application WHERE NAME_CONTRACT_STATUS='Approved')",
          "description": "历史批准次数"
        },
        {
          "name": "prev_approval_rate",
          "formula": "COUNT(WHERE STATUS='Approved') / COUNT(*)",
          "description": "批准率 - 强特征"
        },
        {
          "name": "prev_avg_credit_amount",
          "formula": "AVG(previous_application.AMT_CREDIT)",
          "description": "平均批准金额"
        },
        {
          "name": "prev_credit_to_application_ratio",
          "formula": "AVG(AMT_CREDIT / AMT_APPLICATION)",
          "description": "平均批准/申请比例 - 强特征"
        },
        {
          "name": "prev_max_days_decision",
          "formula": "MAX(previous_application.DAYS_DECISION)",
          "description": "最长决策时间"
        }
      ]
    },
    {
      "category": "bureau_aggregation",
      "priority": "MEDIUM",
      "examples": [
        {
          "name": "bureau_active_debt_sum",
          "formula": "SUM(bureau.AMT_CREDIT_SUM_DEBT WHERE CREDIT_ACTIVE='Active')",
          "description": "活跃信贷的总欠款"
        },
        {
          "name": "bureau_overdue_count",
          "formula": "COUNT(bureau WHERE CREDIT_DAY_OVERDUE > 0)",
          "description": "有逾期记录的信贷数量"
        },
        {
          "name": "bureau_max_overdue_amount",
          "formula": "MAX(bureau.AMT_CREDIT_MAX_OVERDUE)",
          "description": "历史最大逾期金额"
        }
      ]
    },
    {
      "category": "installments_aggregation",
      "priority": "LOW",
      "examples": [
        {
          "name": "installments_count",
          "formula": "COUNT(installments_payments)",
          "description": "分期还款期数"
        },
        {
          "name": "installments_total_payment",
          "formula": "SUM(installments_payments.AMT_PAYMENT)",
          "description": "累计实际还款金额"
        }
      ]
    }
  ],
